# ============================================================
#  GenLayer Agent Studio — environment
#  Copy to ".env.local" for local dev. The app runs fully in
#  MOCK mode with NONE of these set, so it deploys out of the box.
# ============================================================

# ---- Wallet connection (client-side, safe to expose) ------
NEXT_PUBLIC_APP_NAME=GenLayer Agent Studio
# Default testnet chain id (84532 = Base Sepolia).
NEXT_PUBLIC_DEFAULT_CHAIN_ID=84532
# WalletConnect project id (free at https://cloud.reown.com). Optional:
# leave blank and Rabby / MetaMask / Coinbase still work.
NEXT_PUBLIC_WC_PROJECT_ID=

# ---- Mode switches ----------------------------------------
# "mock" = simulated, no creds (default). "live" = real protocols.
# AI_MODE=live calls GenLayer for agent decisions.
AI_MODE=mock
# TX_MODE=live sends real testnet transactions from the connected wallet.
TX_MODE=mock

# ---- GenLayer (only when AI_MODE=live) --------------------
# Address of the deployed AgentRegistry Intelligent Contract.
GENLAYER_CONTRACT_ADDRESS=
# Chain: testnetAsimov | testnetBradbury | studionet
GENLAYER_CHAIN=testnetAsimov
# Signer key for decision txs. Use a KMS/signer in production, not a raw key.
GENLAYER_PRIVATE_KEY=

# ---- Persistence (optional) -------------------------------
# With these set, agents are saved server-side keyed by the connected wallet,
# so they follow the user across devices. Without them, the app uses per-browser
# localStorage. Provision a free store in Vercel: Storage -> Upstash Redis (KV),
# which injects these automatically. (Also works with any Upstash Redis.)
KV_REST_API_URL=
KV_REST_API_TOKEN=
