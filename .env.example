# ============================================================
#  GenLayer + Arc AI Agent Kit — environment
#  Copy to ".env.local" for local dev. The app runs fully in
#  MOCK mode with NONE of these set, so it deploys out of the box.
# ============================================================

# ---- Mode switches ----------------------------------------
# "mock" = simulated, no chain creds needed (default).
# "live" = call real GenLayer / Arc (requires the vars below).
ADJUDICATOR_MODE=mock
SETTLEMENT_MODE=mock

# ---- Platform economics (Arc monetization) ----------------
# Fee captured from a successful release, in basis points (250 = 2.5%).
PLATFORM_FEE_BPS=250
PLATFORM_FEE_RECIPIENT=0x0000000000000000000000000000000000000000

# ---- GenLayer (only when ADJUDICATOR_MODE=live) -----------
# Address of the deployed EscrowAdjudicator Intelligent Contract.
GENLAYER_CONTRACT_ADDRESS=
# Chain id: testnetAsimov | testnetBradbury | studionet
GENLAYER_CHAIN=testnetAsimov
# Signer key for adjudication txs. In production use a KMS/signer, not a raw key.
GENLAYER_PRIVATE_KEY=

# ---- Arc (only when SETTLEMENT_MODE=live) -----------------
ARC_RPC_URL=
ARC_USDC_ADDRESS=
# Operator key controlling escrow release/refund. Use a KMS/signer in production.
ARC_OPERATOR_PRIVATE_KEY=
